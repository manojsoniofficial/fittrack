# FitTrack Pro — Environment Variables
# Copy to .env and fill in real values before running locally or in Docker.
# Never commit .env to version control.

# ── Flask ──────────────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-me-in-production-a8f5f167f44f4964e6c998dee827110c
JWT_SECRET_KEY=change-me-jwt-secret-b3f4e8a1c9d2e7f6a5b4c3d2e1f0a9b8

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Used by Flask API and docker-compose
DATABASE_URL=postgresql://fittrack:fittrack_pass@localhost:5432/fittrack_dev
POSTGRES_USER=fittrack
POSTGRES_PASSWORD=fittrack_pass
POSTGRES_DB=fittrack_dev

# ── External Nutrition API (Edamam) ───────────────────────────────────────────
# Leave blank to use built-in fallback food database (no key required)
# Get a free key at: https://developer.edamam.com/
NUTRITION_APP_ID=
NUTRITION_API_KEY=

